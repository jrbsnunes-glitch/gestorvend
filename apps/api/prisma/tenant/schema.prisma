generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/tenant-client"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

// --- Cadastro da empresa (singleton por tenant) ---
//
// Mantemos um único registro de empresa por banco (a empresa "dona" do tenant).
// Os campos cobrem o que é necessário em cabeçalhos de notas, recibos,
// impressões e relatórios. Os atributos fiscais (IE/IM) são opcionais para
// não bloquear cadastros iniciais.
model Company {
  id          String   @id @default(uuid())
  legalName   String
  tradeName   String
  cnpj        String   @unique
  ie          String?
  im          String?
  email       String?
  phone       String?
  address     String?
  city        String?
  state       String?
  zip         String?
  logoUrl     String?
  /// Comprovante térmico interno (não transmite SEFAZ) x planejamento para documento fiscal eletrônico.
  pdvDocumentMode PdvDocumentMode @default(NON_FISCAL_RECEIPT)
  /// Após finalizar venda no PDV, dispara impressão (janela de impressão do navegador na estação do operador).
  saleReceiptAutoPrint Boolean @default(false)
  /// Texto livre (ex.: modelo da impressora, porta USB) — lembrete para TI; não vincula tecnicamente o driver.
  saleReceiptPrinterHint String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fiscalIssuerSettings FiscalIssuerSettings?
}

/// Ambiente SEFAZ autorizador (homologação primeiro).
enum FiscalSefazEnvironment {
  HOMOLOGACAO
  PRODUCAO
}

/// Parâmetros por empresa para emissão NFC-e/NF-e no worker (certificado via env + caminho opcional).
model FiscalIssuerSettings {
  id               String                 @id @default(uuid())
  companyId        String                 @unique
  company          Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sefazEnvironment FiscalSefazEnvironment @default(HOMOLOGACAO)
  /// CRT: 1 SN, 2 SN excesso, 3 normal (tabela NF-e / NT RFB).
  crt              Int                    @default(1)
  /// Sigla UF emitente (maiúsculas), ex.: SP, PR.
  uf               String                 @db.VarChar(2)
  /// Código IBGE município do emitente (7 dígitos) — campo cMunFG em ide.
  municipalityIbge String                 @db.VarChar(7)
  nfceSerie        Int                    @default(1)
  nfeSerie         Int                    @default(1)
  /// Último número NFC-e emitido com sucesso pelo worker (incrementa em transação).
  nfceLastNumber   Int                    @default(0)
  nfeLastNumber    Int                    @default(0)
  /// Caminho absoluto ao .pfx/.p12 no servidor; se vazio, usar env FISCAL_ISSUER_CERT_PATH.
  certificatePath  String?                @db.VarChar(512)
  /// Senha do .pfx (por tenant). Se vazio, usar `FISCAL_ISSUER_CERT_PASSWORD` no servidor.
  /// Manter backup e encriptação em repouso do PostgreSQL em produção.
  certificatePassword String?             @db.VarChar(512)
  /// ID do código de segurança do contribuinte (CSC) NFC-e; se vazio, usar `FISCAL_NFCE_CSC_ID`.
  nfceCscId        String?                @db.VarChar(64)
  /// Token/segredo CSC NFC-e; se vazio, usar `FISCAL_NFCE_CSC`. Não expor em GET da API.
  nfceCsc          String?                @db.VarChar(512)
  /// Último NSU consumido na Distribuição DF-e (polling de NF-e de entrada).
  inboundUltNsu    String?                @db.VarChar(20)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

/// Modo de documento padrão ao finalizar venda no PDV.
enum PdvDocumentMode {
  /// Cupom / comprovante interno sem transmissão SEFAZ.
  NON_FISCAL_RECEIPT
  /// Planejamento para NF-e/NFC-e (Etapa SEFAZ + campos de reforma tributária).
  ELECTRONIC_FISCAL_PLANNED
}

/// Tipo de documento fiscal eletrônico (fila antes da transmissão SEFAZ).
enum FiscalDocumentKind {
  NFC_E
  NF_E
}

/// Ciclo local do documento (worker SEFAZ ainda não implementado).
enum FiscalDocumentStatus {
  QUEUED
  BUILDING_XML
  SENT
  AUTHORIZED
  REJECTED
  ERROR
  CANCELLED
}

/// Situação fiscal parametrizável, reaproveitada por vários produtos (reforma tributária / NF-e futura).
model FiscalSituation {
  id              String    @id @default(uuid())
  code            String    @unique @db.VarChar(48)
  name            String
  description     String?
  exTipi          String?   @db.VarChar(10)
  fiscalOrigin    String?   @db.VarChar(2)
  cstIcms         String?   @db.VarChar(4)
  csosn           String?   @db.VarChar(4)
  cstPis          String?   @db.VarChar(4)
  cstCofins       String?   @db.VarChar(4)
  cfopInternal    String?   @db.VarChar(5)
  cfopInterstate  String?   @db.VarChar(5)
  ibsTestRate     Decimal   @default(0.1) @db.Decimal(8, 4)
  cbsTestRate     Decimal   @default(0.9) @db.Decimal(8, 4)
  regulationNotes String?   @db.Text
  isActive        Boolean   @default(true)
  products        Product[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive])
}

// --- Auth / RBAC ---

model Role {
  id    String @id @default(uuid())
  name  String @unique
  users User[] @relation("UserRoles")
}

model User {
  id             String           @id @default(uuid())
  /// Login na tela do app (slug + username + senha). Separado do e-mail interno.
  username       String           @unique
  email          String           @unique
  passwordHash   String
  name           String
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  roles          Role[]           @relation("UserRoles")
  sales          Sale[]
  stockMoves     StockMovement[]
  cashSessions        CashRegisterSession[]
  cashSessionsReconciled CashRegisterSession[] @relation("CashSessionReconciledBy")
  goodsReceipts  GoodsReceipt[]
  activityLogs   UserActivityLog[]
  permissions    UserPermission[]
}

/// Permissões operacionais concedidas pelo administrador (com senha de autorização).
enum UserPermissionCode {
  SALE_DISCOUNT
  SALE_CANCEL
  FISCAL_DOC_CANCEL
}

model UserPermission {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  code         UserPermissionCode
  passwordHash String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([userId, code])
  @@index([userId])
}

enum ActivityLogAction {
  LOGIN
  CASH_OPEN
  CASH_CLOSE
  RECEIPT
  FISCAL_DOC
  REPORT
  CREATE
  UPDATE
  DELETE
}

/// Auditoria: login, caixa PDV, cupons/NF-e, relatórios e CRUD de cadastros.
model UserActivityLog {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     ActivityLogAction
  summary    String
  entityType String?
  entityRef  String?
  createdAt  DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

// --- Cadastros ---

model Customer {
  id           String   @id @default(uuid())
  document     String?
  name         String
  email        String?
  phone        String?
  creditLimit  Decimal  @default(0) @db.Decimal(14, 2)
  street       String?
  number       String?
  complement   String?
  district     String?
  city         String?
  state        String?
  zip          String?
  segment      String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sales        Sale[]
  receivables  AccountReceivable[]
}

model Supplier {
  id             String          @id @default(uuid())
  document       String?
  legalName      String
  tradeName      String?
  /// Grupo / segmento (filtros em relatórios financeiros, mesmo conceito do cliente).
  segment        String?
  email          String?
  phone          String?
  street         String?
  number         String?
  complement     String?
  district       String?
  city           String?
  state          String?
  zip            String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  payables       AccountPayable[]
  goodsReceipts  GoodsReceipt[]
  productLinks   SupplierProductLink[]
}

model Category {
  id        String     @id @default(uuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

/// NCM (Nomenclatura Comum do Mercosul) — catálogo pesquisável no cadastro de produtos.
model NcmCode {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(10)
  description String?
  createdAt   DateTime @default(now())
}

/// CEST (Código Especificador da Substituição Tributária) — catálogo pesquisável.
model CestCode {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(10)
  description String
  /// Prefixo NCM opcional para filtro (ex.: os 4 primeiros dígitos)
  ncmHint     String?  @db.VarChar(10)
  createdAt   DateTime @default(now())
}

/// Unidade tributável / comercial (UN, KG, etc.) — expansível pelo usuário.
model TaxUnitCode {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(10)
  description String
  createdAt   DateTime @default(now())
}

model Product {
  id          String           @id @default(uuid())
  name        String
  description String?
  /// Código de barras "principal" do produto (sincronizado com a variante
  /// default na UI). Mantemos também o `barcode` por variante para suportar
  /// SKUs com EANs distintos.
  defaultBarcode String?       @db.VarChar(32)
  categoryId  String?
  category    Category?        @relation(fields: [categoryId], references: [id])
  fiscalSituationId String?
  fiscalSituation   FiscalSituation? @relation(fields: [fiscalSituationId], references: [id], onDelete: SetNull)
  /// Gancho Etapa 2 — NF-e
  ncm         String?
  cest        String?
  /// EX_TIPI (opcional) quando aplicável ao NCM
  exTipi      String?          @db.VarChar(10)
  /// Origem da mercadoria (ICMS) 0–8 conforme tabela de origem
  fiscalOrigin String?         @db.VarChar(2)
  /// Unidade tributável (ex.: UN, KG)
  taxUnit     String?          @db.VarChar(10)
  /// Conversão de unidade na entrada NF-e (ex.: CX-12 → 1 CX = 12 unidades no estoque)
  conversion  String?          @db.VarChar(32)
  isActive    Boolean          @default(true)
  /// Número sequencial único para identificação rápida (listagem, PDV, pesquisa por código).
  controlNumber Int              @unique @default(autoincrement())
  /// Controle agregado do produto: menor `minStock` entre as variantes (recalculado ao salvar variantes). Piso 1 por política cadastral.
  inventoryControlMin Decimal @default(1) @db.Decimal(18, 4)
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProductVariant {
  id                 String             @id @default(uuid())
  productId          String
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                String             @unique
  barcode            String?
  retailPrice        Decimal            @db.Decimal(14, 4)
  wholesalePrice     Decimal?           @db.Decimal(14, 4)
  promoPrice         Decimal?           @db.Decimal(14, 4)
  costAverage        Decimal            @default(0) @db.Decimal(14, 4)
  /// Estoque mínimo recomendado (ponto de reposição) — alertas PDV/relatórios. Cadastro não usa valor abaixo de 1.
  minStock           Decimal            @default(1) @db.Decimal(18, 4)
  saleItems          SaleItem[]
  stockBalances      StockBalance[]
  movements          StockMovement[]
  goodsReceiptItems  GoodsReceiptItem[]
  priceHistory       ProductVariantPriceHistory[]
  supplierLinks      SupplierProductLink[]
}

/// Vínculo código do produto no fornecedor (cProd NF-e) → variação interna.
model SupplierProductLink {
  id                  String         @id @default(uuid())
  supplierId          String
  supplier            Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variantId           String
  variant             ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  /// Código do produto na NF-e do fornecedor (tag cProd).
  supplierProductCode String         @db.VarChar(60)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([supplierId, supplierProductCode])
  @@index([variantId])
}

/// Histórico de alterações de preço de venda (varejo) e custo médio por variação.
model ProductVariantPriceHistory {
  id             String           @id @default(uuid())
  variantId      String
  variant        ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)
  /// RETAIL = preço varejo, COST = custo médio
  field          String           @db.VarChar(16)
  previousValue  Decimal          @db.Decimal(14, 4)
  newValue       Decimal          @db.Decimal(14, 4)
  /// MANUAL = cadastro, GOODS_RECEIPT = recálculo na entrada de notas
  source         String           @db.VarChar(24)
  goodsReceiptId String?
  goodsReceipt   GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())

  @@index([variantId, createdAt])
}

// --- Estoque ---

model StockLocation {
  id        String           @id @default(uuid())
  code      String           @unique
  name      String
  isDefault Boolean          @default(false)
  parentId  String?
  parent    StockLocation?   @relation("LocationHierarchy", fields: [parentId], references: [id])
  children  StockLocation[]  @relation("LocationHierarchy")
  balances  StockBalance[]
  movements StockMovement[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model StockBalance {
  variantId  String
  locationId String
  quantity   Decimal         @default(0) @db.Decimal(18, 4)
  variant    ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  location   StockLocation   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([variantId, locationId])
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUST
}

/// Origem da movimentação — permite conciliar Entradas × Vendas × Saídas manuais no fechamento diário.
enum StockMovementSource {
  SALE
  GOODS_RECEIPT
  MANUAL_OUT
  ADJUSTMENT
  TRANSFER
  OTHER
}

enum GoodsReceiptMode {
  /// Entrada com chave de acesso da NF-e (44 dígitos) — espelho para futura integração SEFAZ
  WITH_NFE_KEY
  /// Recebimento avulso / documento não eletrônico / conferência física
  WITHOUT_NFE
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
}

/// Cabeçalho de entrada de mercadorias (espelho simplificado do layout NF-e / SPED).
model GoodsReceipt {
  id               String             @id @default(uuid())
  /// Número de controle sequencial humano-legível.
  controlNumber    Int                @unique @default(autoincrement())
  mode             GoodsReceiptMode
  /// Chave de acesso NF-e (44 caracteres), obrigatória se mode = WITH_NFE_KEY
  nfeAccessKey     String?            @unique @db.VarChar(44)
  supplierId       String?
  supplier         Supplier?          @relation(fields: [supplierId], references: [id])
  /// Número / série / data emissão conforme documento fiscal
  documentNumber   String?
  series           String?
  issueDate        DateTime?
  natureOperation  String?
  totalValue       Decimal?           @db.Decimal(14, 2)
  notes            String?
  status           GoodsReceiptStatus @default(DRAFT)
  postedAt         DateTime?
  userId           String?
  user             User?              @relation(fields: [userId], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  items            GoodsReceiptItem[]
  movements        StockMovement[]
  priceHistories   ProductVariantPriceHistory[]
  payables         AccountPayable[]
  inboundNfeDocument InboundNfeDocument?
}

/// Status do documento NF-e de entrada na fila / cache.
enum InboundNfeStatus {
  /// Apenas resumo (resNFe) — XML completo ainda não liberado.
  RESUMO
  /// XML completo (nfeProc) disponível.
  COMPLETO
  /// Aguardando revisão humana antes do lançamento.
  PENDENTE_REVISAO
  /// Já lançado em GoodsReceipt.
  IMPORTADO
}

/// XML de NF-e de entrada baixado da SEFAZ (Distribuição DF-e).
model InboundNfeDocument {
  id                    String           @id @default(uuid())
  accessKey             String           @unique @db.VarChar(44)
  xmlPath               String           @db.VarChar(512)
  xmlSha256             String           @db.VarChar(64)
  nsu                   String?          @db.VarChar(20)
  sefazCStat            String?          @db.VarChar(3)
  sefazMotivo           String?          @db.VarChar(512)
  status                InboundNfeStatus @default(COMPLETO)
  /// tpEvento da manifestação registrada (ex.: 210210 = Ciência da Operação).
  manifestacaoEvento    String?          @db.VarChar(10)
  /// Protocolo retornado pela SEFAZ na recepção do evento.
  manifestacaoProtocolo String?          @db.VarChar(60)
  emitterCnpj           String?          @db.VarChar(14)
  emitterName           String?          @db.VarChar(200)
  documentNumber        String?          @db.VarChar(20)
  issueDate             DateTime?
  totalValue            Decimal?         @db.Decimal(14, 2)
  /// Quantidade de itens do XML (quando completo).
  itemCount             Int?
  /// Quantidade de itens sem match automático.
  unmatchedCount        Int?
  fetchedAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  goodsReceiptId        String?          @unique
  goodsReceipt          GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)

  @@index([status, fetchedAt])
}

model GoodsReceiptItem {
  id          String         @id @default(uuid())
  receiptId   String
  receipt     GoodsReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  quantity    Decimal        @db.Decimal(18, 4)
  unitCost    Decimal        @db.Decimal(14, 4)
  /// Campos espelho NF-e (produto/serviço)
  ncm         String?
  cfop        String?
  description String?
  /// Código do produto no fornecedor (cProd) — vínculo editável na entrada.
  supplierProductCode String?  @db.VarChar(60)
  /// Unidade informada na NF-e (uCom) — usada na conversão de estoque.
  invoiceUnit         String?  @db.VarChar(10)
}

model StockMovement {
  id               String               @id @default(uuid())
  /// Número de controle sequencial para impressões/conferência.
  controlNumber    Int                  @unique @default(autoincrement())
  type             StockMovementType
  source           StockMovementSource    @default(OTHER)
  variantId        String
  variant          ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  locationId       String
  location         StockLocation        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity         Decimal              @db.Decimal(18, 4)
  unitCost         Decimal?             @db.Decimal(14, 4)
  reference        String?
  /// Motivo em saídas manuais (avaria, perda, consumo interno, etc.)
  outboundReason   String?
  userId           String?
  user             User?                @relation(fields: [userId], references: [id])
  goodsReceiptId   String?
  goodsReceipt     GoodsReceipt?        @relation(fields: [goodsReceiptId], references: [id])
  createdAt        DateTime             @default(now())
}

// --- Vendas / PDV ---

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  PIX
  CREDIT
  OTHER
  /// Saída de caixa classificada como despesa (conciliação / justificativa de falta).
  EXPENSE
}

/// Origem da venda — permite separar PDV físico de pedidos vindos do GestorVendChat (WhatsApp).
enum SaleSource {
  PDV
  WHATSAPP
}

model Sale {
  id            String         @id @default(uuid())
  number        Int            @unique @default(autoincrement())
  status        SaleStatus     @default(COMPLETED)
  source        SaleSource     @default(PDV)
  /// Identificador externo (ex.: Order.id do GestorVendChat) — útil para conciliar com o sistema de origem.
  externalRef   String?        @db.VarChar(64)
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  userId        String?
  user          User?          @relation(fields: [userId], references: [id])
  subtotal      Decimal        @db.Decimal(14, 2)
  discount      Decimal        @default(0) @db.Decimal(14, 2)
  total         Decimal        @db.Decimal(14, 2)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  /// Erro de integração fiscal (NF-e/NFC-e/Sefaz). Impede novo caixa/PDV até resolução quando preenchido.
  fiscalIntegrationError String? @db.VarChar(1024)
  /// Registro de emissão (fila/status) quando o tenant usa documento fiscal — 1 venda ⇄ no máximo 1 fila.
  fiscalDocument         FiscalDocument?
  items                  SaleItem[]
  payments               SalePayment[]
  receivables            AccountReceivable[]
}

/// Metadados da fila de emissão DFe por venda (próximo passo: XML, assinatura, SEFAZ).
model FiscalDocument {
  id               String               @id @default(uuid())
  saleId           String               @unique
  sale             Sale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  kind             FiscalDocumentKind
  status           FiscalDocumentStatus @default(QUEUED)
  /// Próxima janela de tentativa quando houver retry (worker futuro).
  nextAttemptAt    DateTime?
  lastError        String?              @db.VarChar(2048)
  accessKey        String?              @db.VarChar(44)
  protocol         String?              @db.VarChar(32)
  sefazEnvironment String?              @db.VarChar(16)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model SaleItem {
  id          String         @id @default(uuid())
  saleId      String
  sale        Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  quantity    Decimal        @db.Decimal(18, 4)
  unitPrice   Decimal        @db.Decimal(14, 4)
  discount    Decimal        @default(0) @db.Decimal(14, 2)
  totalLine   Decimal        @db.Decimal(14, 2)
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  sale      Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    PaymentMethod
  amount    Decimal       @db.Decimal(14, 2)
  installments Int        @default(1)
}

// --- Caixa ---

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  IN
  OUT
}

model CashRegisterSession {
  id             String          @id @default(uuid())
  /// Número sequencial humano-legível ("controle") para identificação rápida
  /// nos relatórios e na conferência diária. Incrementado automaticamente.
  controlNumber  Int             @unique @default(autoincrement())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  status         CashSessionStatus @default(OPEN)
  openingBalance Decimal         @default(0) @db.Decimal(14, 2)
  closingBalance Decimal?        @db.Decimal(14, 2)
  /// Valores apresentados pelo operador no fechamento, por forma de pagamento.
  /// Estrutura: { "CASH": "1234.56", "CARD": "...", "PIX": "...", ... }.
  /// Mantido como Json para flexibilidade caso novos métodos sejam adicionados.
  closingByMethod Json?
  /// Observações livres registradas pelo operador ao fechar o caixa.
  closingNotes   String?
  /// Conferência (gerente): quando o fluxo de fechamento foi auditado.
  reconciledAt          DateTime?
  reconciledByUserId    String?
  reconciledBy          User?           @relation("CashSessionReconciledBy", fields: [reconciledByUserId], references: [id], onDelete: SetNull)
  /// Observações do gerente na conferência (ex.: motivo de diferença).
  reconciliationNotes   String?         @db.Text
  /// Opcional — detalhamento linha a linha das despesas apresentadas (valor, observação, centro).
  reconciliationExpenseDetails Json?
  openedAt       DateTime        @default(now())
  closedAt       DateTime?
  movements      CashMovement[]
  payableSettlements   AccountPayable[]
  receivableSettlements AccountReceivable[]
  payablePaymentSettlements    PayableSettlement[]    @relation("PayableSettlementSession")
  receivablePaymentSettlements ReceivableSettlement[] @relation("ReceivableSettlementSession")
}

model CashMovement {
  id        String              @id @default(uuid())
  sessionId String
  session   CashRegisterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      CashMovementType
  amount    Decimal               @db.Decimal(14, 2)
  method    PaymentMethod?
  reason    String?
  /// Centro de custo (conta do plano referencial — grupos 4/5 saída, 6 entrada).
  referentialAccountId String?
  referentialAccount   ReferentialAccount? @relation(fields: [referentialAccountId], references: [id], onDelete: SetNull)
  createdAt DateTime              @default(now())

  @@index([referentialAccountId])
}

// --- Financeiro ---

enum BillStatus {
  OPEN
  PAID
  OVERDUE
  CANCELLED
}

/// Periodicidade para contas fixas. NONE = título único.
enum Recurrence {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

model AccountPayable {
  id             String     @id @default(uuid())
  supplierId     String?
  supplier       Supplier?  @relation(fields: [supplierId], references: [id])
  description    String
  category       String?
  amount         Decimal    @db.Decimal(14, 2)
  /// Saldo ainda em aberto (pagamentos parciais reduzem até zero).
  amountRemaining Decimal   @db.Decimal(14, 2)
  dueDate        DateTime
  paidAt         DateTime?
  status         BillStatus @default(OPEN)
  /// Vínculo opcional com a entrada (nota) que originou a conta.
  goodsReceiptId String?
  goodsReceipt   GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  /// Quando o título nasce de uma série recorrente.
  recurrence     Recurrence @default(NONE)
  /// Número da parcela na série (1, 2, 3…).
  recurrenceIndex Int?
  /// Total de parcelas geradas na série.
  recurrenceCount Int?
  /// Aponta para o primeiro título da série (a "âncora" da recorrência).
  parentRecurringId String?
  parentRecurring   AccountPayable? @relation("PayableRecurringChildren", fields: [parentRecurringId], references: [id])
  recurringChildren AccountPayable[] @relation("PayableRecurringChildren")
  paymentMethod   PaymentMethod?
  settledAmount   Decimal?    @db.Decimal(14, 2)
  cashSessionId   String?
  cashSession     CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  paymentNotes    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  settlements   PayableSettlement[]
}

/// Cada liquidação (parcial ou total) de conta a pagar — valor efetivo pago e diário.
model PayableSettlement {
  id            String     @id @default(uuid())
  payableId     String
  payable       AccountPayable @relation(fields: [payableId], references: [id], onDelete: Cascade)
  amount        Decimal    @db.Decimal(14, 2)
  paidAt        DateTime   @default(now())
  method        PaymentMethod?
  cashSessionId String?
  cashSession   CashRegisterSession? @relation("PayableSettlementSession", fields: [cashSessionId], references: [id], onDelete: SetNull)
  notes         String?    @db.VarChar(4000)
  referentialAccountId String?
  referentialAccount   ReferentialAccount? @relation(fields: [referentialAccountId], references: [id], onDelete: SetNull)

  @@index([payableId])
  @@index([paidAt])
  @@index([referentialAccountId])
}

model AccountReceivable {
  id          String     @id @default(uuid())
  customerId  String?
  customer    Customer?  @relation(fields: [customerId], references: [id])
  saleId      String?
  sale        Sale?      @relation(fields: [saleId], references: [id])
  description String
  amount         Decimal    @db.Decimal(14, 2)
  /// Saldo ainda em aberto (pagamentos parciais reduzem até zero).
  amountRemaining Decimal   @db.Decimal(14, 2)
  dueDate     DateTime
  receivedAt  DateTime?
  status      BillStatus @default(OPEN)
  recurrence     Recurrence @default(NONE)
  recurrenceIndex Int?
  recurrenceCount Int?
  parentRecurringId String?
  parentRecurring   AccountReceivable? @relation("ReceivableRecurringChildren", fields: [parentRecurringId], references: [id])
  recurringChildren AccountReceivable[] @relation("ReceivableRecurringChildren")
  paymentMethod   PaymentMethod?
  settledAmount   Decimal?    @db.Decimal(14, 2)
  cashSessionId   String?
  cashSession     CashRegisterSession? @relation(fields: [cashSessionId], references: [id])
  paymentNotes    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  settlements ReceivableSettlement[]
}

model ReceivableSettlement {
  id             String   @id @default(uuid())
  receivableId   String
  receivable     AccountReceivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(14, 2)
  receivedAt     DateTime @default(now())
  method         PaymentMethod?
  cashSessionId  String?
  cashSession    CashRegisterSession? @relation("ReceivableSettlementSession", fields: [cashSessionId], references: [id], onDelete: SetNull)
  notes          String?  @db.VarChar(4000)
  referentialAccountId String?
  referentialAccount   ReferentialAccount? @relation(fields: [referentialAccountId], references: [id], onDelete: SetNull)

  @@index([receivableId])
  @@index([receivedAt])
  @@index([referentialAccountId])
}

/// Contas do Plano Referencial (RFB / SPED ECD) — versão importada; somente leitura na UI v1.
model ReferentialAccount {
  id            String    @id @default(uuid())
  /// Código oficial da conta referencial.
  code          String
  description   String
  level         Int       @default(1)
  parentCode    String?
  validFrom     DateTime?
  validTo       DateTime?
  /// Taxonomia / natureza quando aplicável (ex.: atributo do layout).
  taxonomyCode  String?
  /// Identificador da versão da importação (ex.: layout ECD, arquivo-fonte).
  sourceVersion String    @default("RFB-sample-v1")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cashMovements           CashMovement[]
  payableSettlements      PayableSettlement[]
  receivableSettlements   ReceivableSettlement[]

  @@unique([code, sourceVersion])
  @@index([code])
  @@index([parentCode])
  @@index([sourceVersion])
}

// --- Auditoria ---

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())
}

// --- Etapa 2 (gancho) — desabilitado por padrão na aplicação ---

model FiscalConfig {
  id        String   @id @default(uuid())
  regime    String?
  notes     String?
  updatedAt DateTime @updatedAt
}
