# GestorVend — bloco Nginx (exemplo).
# Copie para sites-available (ex.: /etc/nginx/sites-available/gestorvend),
# ajuste server_name, root e certificados, depois:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Caminhos típicos após clone em /opt/gestorvend:
#   root /opt/gestorvend/apps/web/dist;
#
# Certificado Let's Encrypt (exemplo):
#   sudo certbot certonly --webroot -w /var/www/certbot -d gestorvend.seudominio.com

upstream gestorvend_api {
    server 127.0.0.1:3000;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name gestorvend.seudominio.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name gestorvend.seudominio.com;

    ssl_certificate     /etc/letsencrypt/live/gestorvend.seudominio.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/gestorvend.seudominio.com/privkey.pem;

    root /opt/gestorvend/apps/web/dist;
    index index.html;

    # API Nest (prefixo global /api)
    location /api {
        proxy_pass http://gestorvend_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    # SPA (React + /portal-admin)
    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml+rss;
}
