{
  "name": "gestorvend",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared-types"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run start:dev -w @gestorvend/api",
    "dev:web": "npm run dev -w @gestorvend/web",
    "build": "npm run build -w @gestorvend/api && npm run build -w @gestorvend/web",
    "db:generate": "npm run prisma:generate -w @gestorvend/api",
    "db:migrate:central": "npm run prisma:migrate:central -w @gestorvend/api",
    "db:migrate:tenant": "npm run prisma:migrate:tenant -w @gestorvend/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
