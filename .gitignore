# GestorVend — o que não entra no GitHub (código, migrations, docs de produto e
# *.example de ambiente continuam versionados).

# --- Dependências ---
node_modules/

# --- Build e artefatos gerados ---
dist/
build/
out/
.next/
*.tsbuildinfo
*.eslintcache
.cache/
.parcel-cache/
apps/api/dist/
apps/web/dist/

# --- Variáveis de ambiente e segredos ---
# Templates permitidos: .env.example (raiz), apps/web/.env.development.example
.env
.env.local
.env.*.local
apps/api/.env
apps/web/.env
apps/web/.env.local
apps/web/.env.development
apps/web/.env.production
apps/web/.env.production.local

# --- Prisma — client gerado (npm run prisma:generate na API) ---
apps/api/src/generated/

# --- Logs, scratch e temporários ---
logs/
tmp/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tmp
*.temp

# --- Testes e cobertura ---
coverage/
.nyc_output/
*.lcov
junit.xml

# --- Sistema operacional ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs / editores ---
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# --- Ferramentas e deploy local ---
.turbo/
.vercel/
.netlify/
*.pid

# --- Dumps, backups e dados locais ---
*.dump
*.sql.backup
data/uploads/
apps/api/data/

# --- Chaves e certificados (nunca commitar) ---
*.pem
*.p12
id_rsa
id_rsa.pub

