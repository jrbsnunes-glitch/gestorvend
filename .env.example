# Raiz — copie para .env e ajuste
# Em VPS atrás do Nginx, use HOST=127.0.0.1 para escutar só em loopback.
HOST=0.0.0.0
PORT=3000

CENTRAL_DATABASE_URL=postgresql://gestorvend:gestorvend@localhost:5433/gestorvend_central
TENANT_DATABASE_URL=postgresql://gestorvend:gestorvend@localhost:5433/gestorvend_tenant_dev
# Opcional: usuário com permissão CREATE DATABASE (recomendado em produção). Se vazio, usa TENANT_DATABASE_URL.
TENANT_ADMIN_DATABASE_URL=

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Módulo fiscal (Etapa 2) — desligado até homologação
# Passo a passo mínimo (env + /empresa + fila PDV): docs/FISCAL-HOMOLOG-NFC-E.md
FISCAL_MODULE_ENABLED=false

# --- Emissão NFC-e (servidor/API) — fallback quando o tenant não preenche na UI (Empresa / emissor) ---
# Caminho absoluto ao certificado .pfx quando não usar o campo certificatePath salvo por tenant no banco.
FISCAL_ISSUER_CERT_PATH=
# Senha do .pfx quando não estiver guardada por tenant em FiscalIssuerSettings.certificatePassword.
FISCAL_ISSUER_CERT_PASSWORD=
# CSC NFC-e quando não estiver guardado por tenant (FiscalIssuerSettings.nfceCscId / nfceCsc).
FISCAL_NFCE_CSC_ID=
FISCAL_NFCE_CSC=
# Transporte real à SEFAZ: use `dry-run` (padrão) para validar só assinatura+XML ou `soap`.
FISCAL_EMIT_TRANSPORT=dry-run
# URL opcional SOAP homolog/prod NFC-e (NFeAutorizacao4) — confirme com o Estado.
# Ex.: https://nfce-homologacao.svrs.rs.gov.br/ws/NfeAutorizacao/NFeAutorizacao4.asmx
FISCAL_SEFAZ_NFCE_SOAP_URL=
# URL opcional SOAP NF-e modelo 55 (mesmo serviço Autorizacao4 na SVRS; ajuste por UF).
FISCAL_SEFAZ_NFE_SOAP_URL=
# URL opcional inutilização (NFeInutilizacao4).
# FISCAL_SEFAZ_INUTILIZACAO_URL=
# Consulta página QR opcional (ajuste UF/ambiente).
FISCAL_NFCE_QR_BASE_URL=
# URL consultada no infNFeSupl (urlChave) — opcional.
# FISCAL_NFCE_URL_CHAVE=

REDIS_URL=redis://localhost:6380

# Arquivos enviados (logotipo por tenant). Em produção, use volume persistente.
UPLOAD_DIR=./data/uploads

# XMLs de NF-e de entrada baixados da SEFAZ (volume persistente na VPS).
NFE_INBOUND_DIR=./data/nfe-inbound
# XMLs de NF-e/NFC-e emitidas (saída).
NFE_OUTBOUND_DIR=./data/nfe-outbound
# Transporte: soap (consulta SEFAZ) ou dry-run (bloqueia download — só validações locais).
FISCAL_INBOUND_TRANSPORT=soap
# URL opcional do NFeDistribuicaoDFe (padrão: hom.nfe.fazenda.gov.br ou www1.nfe.fazenda.gov.br)
# FISCAL_INBOUND_DISTRIBUICAO_URL=

# Bridge GestorVendChat (vendas via WhatsApp) — gere um UUID e use o mesmo valor no GestorVendChat.
# Liberada por tenant via Tenant.planCode = 'WHATSAPP'. Deixe vazio para desativar a bridge.
WACHAT_API_KEY=
